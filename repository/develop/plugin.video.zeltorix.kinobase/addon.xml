<?xml version='1.0' encoding='utf-8'?>
<addon id="plugin.video.zeltorix.kinobase" name="Kinobase (Тест)" version="0.0.5" provider-name="Zeltorix">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
        <import addon="xbmc.gui" version="5.15.0" />
        <import addon="xbmc.addon" version="19.1.0" />
        <import addon="inputstream.adaptive" version="19.0.0" />
        <import addon="script.module.beautifulsoup4" version="0.0.1" />
        <import addon="script.module.zeltorix.utilitys" version="0.0.124" />
    </requires>

    <extension point="xbmc.python.pluginsource" library="addon.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.video" library="addon.py">
        <provides>video</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">For site kinobase</summary>
        <summary lang="ru_RU">Для сайта kinobase</summary>
        <description lang="en_GB">To watch video on the kinobase</description>
        <description lang="ru_RU">Для просмотра видео доступных на сайте kinobase</description>
        <disclaimer lang="en_GB">For Kodi «Matrix» 19</disclaimer>
        <disclaimer lang="ru_RU">Для Kodi «Matrix» 19 и выше</disclaimer>
        <news>
            v0.0.1 (2023-12-07)
                [new]
                [fix]
            ...
            v0.0.1 (2023-12-07)
                [new] Старт проекта
                [fix]
        </news>
        <platform>all</platform>
        <language>ru en
        </language> 
        <license>GPL-3-or-later</license>
        <forum />
        <source>https://github.com/Zeltorix/kodi/raw/main/source/release/kinobase</source>
        <assets>
            <icon>icon.jpg</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
        <reuselanguageinvoker>true</reuselanguageinvoker>
        <debugging>true</debugging>
    </extension>
</addon>