        </news>
        <platform>all</platform>
        <language>ru en
        </language> 
        <license>GPL-3-or-later</license>
        <forum>http://xbmc.ru/forum/showthread.php?t=26919</forum>
        <source>https://github.com/Zeltorix/kodi/source/release/anilibria</source>
